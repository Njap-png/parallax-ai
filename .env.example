# Parallax Dominion - Environment Variables Template
# Copy this file to .env.production and fill in your values

# AI Services
GROQ_API_KEY=your_groq_api_key_here
# Get Groq key: https://console.groq.com

# Supabase (Database & Auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=your@domain.com
EMAIL_FROM_NAME=Parallax Dominion

# Payments (Paystack)
PAYSTACK_PUBLIC_KEY=pk_live_your_public_key
PAYSTACK_SECRET_KEY=sk_live_your_secret_key
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret

# Paystack Plan Codes
PAYSTACK_STARTER_PLAN=PLN_starter_code
PAYSTACK_PRO_PLAN=PLN_pro_code
PAYSTACK_ENTERPRISE_PLAN=PLN_enterprise_code

# App Configuration
APP_URL=https://your-domain.vercel.app
API_URL=https://your-domain.vercel.app/api

# Admin
ADMIN_EMAIL=admin@your-domain.com
JWT_SECRET=your_secure_jwt_secret_minimum_32_chars

# Code Execution (CodAPI - optional)
CODAPI_KEY=your_codapi_key
# CodAPI cloud is free: https://codapi.org

# Rate Limits (per plan - optional)
RATE_LIMIT_FREE=100
RATE_LIMIT_STARTER=10000
RATE_LIMIT_PRO=100000
RATE_LIMIT_ENTERPRISE=1000000
